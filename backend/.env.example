# OpenAI (for PDF extraction)
OPENAI_API_KEY=sk-proj-your-openai-key-here
OPENAI_MODEL=gpt-4o

# Backend server port
PORT=3000

# MYOB Advanced (Acumatica) — REST endpoint auth
MYOB_HOST=https://your-tenant.myobadvanced.com
MYOB_API_PATH=/entity/Default/24.200.001
MYOB_USERNAME=your-api-username
MYOB_PASSWORD=your-api-password
MYOB_COMPANY_NAME=Training
# Optional — branch ID if your MYOB has multiple branches
# MYOB_BRANCH=

# Optional — default customer ID used when lookup fails
# MYOB_DEFAULT_CUSTOMER_ID=C0001

# Line-level custom field names for Pieces / Length (Acumatica internal names,
# discovered via GET /api/myob/schema on your MYOB instance)
MYOB_LINE_PIECES_FIELD=UsrACSNoOfPeices
MYOB_LINE_LENGTH_FIELD=UsrACSLength
MYOB_LINE_CUSTOM_VIEW=Transactions
